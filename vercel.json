{
  "version": 2,
  "public": true,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/(.*)", "dest": "/public/$1" }
  ],
  "env": {
    "RESEND_API_KEY": "@resend_api_key",
    "AIRTABLE_API_KEY": "@airtable_api_key",
    "AIRTABLE_BASE_ID": "@airtable_base_id",
    "NOTIFY_EMAIL": "@notify_email"
  }
}
